rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}  (the Firebase Auth uid)
// Fields:
//   - credits: number   (required) - remaining quota for resource-heavy tools
//   - role: string       (optional) - "user" | "manager" | "admin"; defaults to
//                         "user" when absent. Mirrored into the Firebase custom
//                         claim `role` (see src/lib/auth/roles.server.ts).
//   - createdAt: timestamp (required, immutable) - when the account doc was made
//   - updatedAt: timestamp (optional) - last server mutation
//
// WRITE MODEL (critical): both `credits` and `role` are mutated ONLY on the
// server via the Firebase Admin SDK, which BYPASSES these rules entirely.
// Therefore clients are never allowed to write this collection — they may only
// READ their own document. This makes client-side credit/role tampering
// impossible by construction (a client cannot escalate its own role), and the
// server enforces atomicity with transactions (see src/lib/credits.ts) to
// prevent race-condition double-spend. Role enforcement never trusts the client:
// it reads the role from the verified ID token / Firestore on the server.
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- User accounts (credits / quota) ---
    match /users/{userId} {
      // Owner may read their own account (contains only their own data).
      allow read: if isOwner(userId);
      // All writes go through the Admin SDK on the server — never the client.
      allow write: if false;
    }

    // --- Default deny everything else ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
