# Canonical public origin of the site (no trailing slash). Used for SEO:
# metadataBase, canonical URLs, sitemap, robots, Open Graph. Safe to expose.
# Defaults to https://www.toollord.online when unset.
NEXT_PUBLIC_SITE_URL=https://www.toollord.online

# Server-side secret key of the web app. Combined with the user's key to
# encrypt/decrypt messages. Keep this out of version control.
# Change this to your own long random string in production.
WEB_SECRET_KEY=change-me-to-a-long-random-web-secret-key

# --- Firebase (client SDK) ---------------------------------------------------
# Safe to expose to the browser (NEXT_PUBLIC_*). Copy from Firebase Console ->
# Project Settings -> General -> Your apps -> SDK setup and configuration.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional:
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# --- Firebase Admin SDK (server-only secret) ---------------------------------
# From Firebase Console -> Project Settings -> Service accounts ->
# Generate new private key. NEVER prefix these with NEXT_PUBLIC.
# FIREBASE_PRIVATE_KEY keeps its literal "\n" sequences; the code converts them.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Cloudflare R2 (server-only, S3-compatible) ------------------------------
# Used by the "secret-image" tool to store CLIENT-ENCRYPTED image blobs.
# These are server-only secrets — never prefix with NEXT_PUBLIC. The browser
# never sees them; it only ever receives short-lived presigned URLs.
#   R2_ACCOUNT_ID        : Cloudflare account id (the R2 endpoint subdomain).
#   R2_ACCESS_KEY_ID     : R2 API token access key id.
#   R2_SECRET_ACCESS_KEY : R2 API token secret.
#   R2_BUCKET            : bucket name that holds the encrypted blobs.
# The bucket needs a CORS policy allowing GET+PUT from every web origin (dev +
# production) so the browser can upload/download blobs directly via the
# presigned URLs. Origin = scheme + host only (no trailing slash / path), e.g.:
#   [{ "AllowedOrigins": ["http://localhost:3000", "https://www.toollord.online"],
#      "AllowedMethods": ["GET","PUT"],
#      "AllowedHeaders": ["*"], "MaxAgeSeconds": 3600 }]
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Storage cap for the secret-image tool. When the bucket reaches this many
# gigabytes, the server refuses ALL new uploads (existing albums still viewable).
# Leave empty/unset to disable the cap (unlimited). Example: 10
R2_MAX_STORAGE_GB=10
